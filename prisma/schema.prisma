// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// 1. CATALOGO DE EMPLEADOS [cite: 1]
model Empleados {
  Email                  String    @id @db.VarChar(50)
  Password               String
  Pin_Temporal           String?
  Expiracion_Pin         DateTime?
  Ultimo_Cambio_Password DateTime?
  Nombre_Empleado        String    @db.VarChar(60)
  A_Paterno              String    @db.VarChar(60)
  Estatus_Acceso         String    @default("Activo")
  A_Materno              String?   @db.VarChar(60)
  Cargo                  String?   @db.VarChar(60)
  Departamento           String?   @db.VarChar(80)
  Rol                    String    @default("USER")

  // Relaciones
  telefonos                 Telefono[]
  autos_encargados          Inventario_Automoviles[]       @relation("EncargadoAuto")
  historial_autos           Historial_Registro_Automovil[]
  historial_propios         Historial_Empleados[]
  solicitudes               Solicitud[]
  procesos                  Procesos[]
  inventarioComputos        Inventario_Computo[]
  historialRegistroComputos Historial_Registro_Computo[]
  solicitudComputos         Solicitud_Computo[]
}

// 2. INVENTARIO DE UNIDADES [cite: 2]
model Inventario_Automoviles {
  Consecutivo       String  @id @db.VarChar(10)
  Placa             String  @unique @db.VarChar(20)
  Marca             String? @db.VarChar(50)
  Modelo            String? @db.VarChar(50)
  Color             String? @db.VarChar(40)
  Linea             String? @db.VarChar(20)
  Estado_Unidad     Boolean @default(true)
  Estatus_Operativo String  @default("Activo en flota") @db.VarChar(30)
  Email_encargado   String? @db.VarChar(100)
  Numero_Serie      String?
  Poliza_Seguro     String?
  Departamento      String?
  Contrato          String?
  Ubicacion         String?
  Percance          String?
  Kilometraje       Int?

  // Relaciones
  encargado      Empleados?                     @relation("EncargadoAuto", fields: [Email_encargado], references: [Email])
  historial_reg  Historial_Registro_Automovil[]
  bitacora_autos Historial_Auto[]
  solicitudes    Solicitud[]
  checklists     Checklist[]
  documentos     Documentos_Unidad[]
  costos         Costos_Mantenimiento[]
  verificaciones Verificacion_Vehicular[]
}

// 3. TELEFONOS DE EMPLEADOS [cite: 3]
model Telefono {
  Email_Empleado String @db.VarChar(50)
  No_Telefonico  String @db.VarChar(15)

  empleado Empleados @relation(fields: [Email_Empleado], references: [Email], onDelete: Cascade)

  @@id([Email_Empleado, No_Telefonico]) // Llave primaria compuesta
}

// 4. HISTORIAL DE CAMBIOS EN EL INVENTARIO [cite: 4]
model Historial_Registro_Automovil {
  Id_Historial_Reg Int      @id @default(autoincrement())
  Consecutivo      String   @db.VarChar(10)
  Placa            String?  @db.VarChar(10)
  Marca            String?  @db.VarChar(20)
  Modelo           String?  @db.VarChar(20)
  Color            String?  @db.VarChar(15)
  Linea            String?  @db.VarChar(15)
  Email_Personal   String?  @db.VarChar(50)
  Fecha_Cambio     DateTime @default(now())

  // Relaciones
  auto     Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
  empleado Empleados?             @relation(fields: [Email_Personal], references: [Email])
}

// 5. BITACORA DE SERVICIOS [cite: 6]
model Historial_Auto {
  Id_Historial   Int      @id @default(autoincrement())
  Consecutivo    String   @db.VarChar(10)
  Placa_Actual   String?  @db.VarChar(10)
  Kilometraje    Int?
  Estado_Actual  Boolean  @default(true)
  Descripcion    String?  @db.Text
  Fecha_Registro DateTime @default(now())

  auto Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

// 6. CHECKLISTS EN PDF
model Checklist {
  id           Int      @id @default(autoincrement())
  Consecutivo  String
  Titulo       String
  Ruta_PDF     String // Aquí guardaremos el nombre del archivo (ej. /uploads/VSI-011-check.pdf)
  Fecha_Subida DateTime @default(now())

  // Relación: Este checklist pertenece a un auto específico
  vehiculo Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

// 6.2. DOCUMENTOS DE UNIDAD
model Documentos_Unidad {
  id           Int      @id @default(autoincrement())
  Consecutivo  String   @db.VarChar(10)
  Titulo       String   @db.VarChar(100)
  Ruta_PDF     String   @db.Text
  Fecha_Subida DateTime @default(now())

  Fecha_Expiracion DateTime? @db.Date
  Aviso_Dias       Int?
  Notificado       Boolean   @default(false)

  // Relación: Este documento pertenece a un auto específico
  vehiculo Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

// 7. HISTORIAL DE TRAYECTORIA DE EMPLEADOS [cite: 7]
model Historial_Empleados {
  Id_Historial_Emp Int      @id @default(autoincrement())
  Email_Empleado   String   @db.VarChar(50)
  Nombre           String?  @db.VarChar(60)
  A_Paterno        String?  @db.VarChar(60)
  A_Materno        String?  @db.VarChar(60)
  Cargo            String?  @db.VarChar(60)
  Departamento     String?  @db.VarChar(80)
  Fecha_Cambio     DateTime @default(now())

  empleado Empleados @relation(fields: [Email_Empleado], references: [Email], onDelete: Cascade)
}

// 8. SOLICITUD (Tickets) [cite: 8]
model Solicitud {
  Pk_folio_ticket   String   @id @db.VarChar(25) // Se genera por Trigger en BD
  Consecutivo       String   @db.VarChar(10)
  Email_Empleado    String   @db.VarChar(50)
  Lugar_Cita        String?  @db.Text
  Asesor            String?  @db.VarChar(50)
  Fecha_Cita        String?  @db.VarChar(50)
  Hora_Cita         String?  @db.VarChar(20)
  Num_Asesor        String?
  Link_Taller       String?  @db.Text
  Kilometraje       Int?
  Tipo_Servicio     String?  @db.VarChar(30)
  Evidencia         String? // Usado históricamente para Facturas
  Foto_Evidencia    String? // Nuevo campo para la fotografía del ticket
  Descripcion       String?  @db.Text
  Fecha_Realizacion DateTime @default(now()) @db.Date
  Estado            String   @default("PENDIENTE")

  auto     Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo])
  empleado Empleados              @relation(fields: [Email_Empleado], references: [Email])
  procesos Procesos[]
}

// 9. PROCESOS (Seguimiento) [cite: 9]
model Procesos {
  Id_Proceso      Int      @id @default(autoincrement())
  Pk_folio_ticket String   @db.VarChar(25)
  Email_Empleado  String   @db.VarChar(50)
  Detalle_Proceso String?  @db.Text
  Fecha_Hora      DateTime @default(now())

  ticket   Solicitud @relation(fields: [Pk_folio_ticket], references: [Pk_folio_ticket], onDelete: Cascade)
  empleado Empleados @relation(fields: [Email_Empleado], references: [Email])
}

// 10. COSTOS DE MANTENIMIENTO [cite: 10]
model Costos_Mantenimiento {
  Id_Costo          Int      @id @default(autoincrement())
  Fecha             DateTime
  Servicio          String   @db.Text
  Consecutivo       String   @db.VarChar(10)
  Costo_MO          Float
  Costo_Refacciones Float
  Total             Float
  Proveedor         String   @db.Text
  Empresa           String   @db.Text
  Tipo_Mtto         String   @db.Text
  Factura_CDG       String?  @db.Text

  // Relacion
  auto Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

// 11. VERIFICACIONES VEHICULARES
model Verificacion_Vehicular {
  Id_Verificacion Int    @id @default(autoincrement())
  Consecutivo     String @db.VarChar(10)

  Anio    Int // Año de la verificación (ej. 2024, 2025)
  Periodo Int // 1 (Primer Semestre) o 2 (Segundo Semestre)

  // Plazo (Esperado según la placa)
  Fecha_Inicio_Plazo DateTime @db.Date
  Fecha_Fin_Plazo    DateTime @db.Date

  // Real (Cuando realmente se hizo)
  Fecha_Realizacion DateTime? @db.Date
  Evidencia_PDF     String?   @db.Text
  Costo             Float?

  Estado String @default("PENDIENTE") // PENDIENTE, REALIZADO, VENCIDO

  // Relación
  vehiculo Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

// 12. PROGRAMA ANUAL DE MANTENIMIENTO
model Programa_Anual {
  Id_Programa   Int     @id @default(autoincrement())
  Anio          Int
  Categoria     String
  Ejecuta       String
  Observaciones String? @db.Text

  meses Programa_Mes[]

  @@unique([Anio, Categoria])
}

model Programa_Mes {
  Id          Int     @id @default(autoincrement())
  Id_Programa Int
  Mes         Int
  Programado  Boolean @default(false)
  Realizado   Boolean @default(false)

  programa Programa_Anual @relation(fields: [Id_Programa], references: [Id_Programa], onDelete: Cascade)

  @@unique([Id_Programa, Mes])
}

// ==========================================
// MÓDULO DE CÓMPUTO
// ==========================================

model Inventario_Computo {
  C_Interno   String  @id @db.VarChar(100)
  Empresa     String? @db.VarChar(100)
  Tipo        String? @db.VarChar(100)
  Marca       String? @db.VarChar(100)
  Modelo      String? @db.VarChar(100)
  Service_Tag String? @db.VarChar(100)
  Cargador    String? @db.VarChar(100)

  Usuario         String? @db.VarChar(100)
  Departamento    String? @db.VarChar(100)
  Puesto_Proyecto String? @db.VarChar(100)
  N_EMP           String? @db.VarChar(100)

  Estatus   String?   @default("Asignado") @db.VarChar(100)
  CR        String?   @db.VarChar(100)
  Fecha_CR  DateTime? @db.Date
  Proveedor String?   @db.VarChar(100)

  Email_Empleado String?    @db.VarChar(100)
  empleado       Empleados? @relation(fields: [Email_Empleado], references: [Email])

  historial_reg Historial_Registro_Computo[]
  documentos    Documentos_Computo[]
  solicitudes   Solicitud_Computo[]
  costos        Costos_Computo[]
}

model Historial_Registro_Computo {
  Id_Historial_Reg Int      @id @default(autoincrement())
  C_Interno        String   @db.VarChar(100)
  Email_Personal   String?  @db.VarChar(100)
  Fecha_Cambio     DateTime @default(now())
  Detalle          String?  @db.Text

  equipo   Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
  empleado Empleados?         @relation(fields: [Email_Personal], references: [Email])
}

model Documentos_Computo {
  id           Int      @id @default(autoincrement())
  C_Interno    String   @db.VarChar(100)
  Titulo       String   @db.VarChar(150)
  Ruta_PDF     String   @db.Text
  Fecha_Subida DateTime @default(now())

  equipo Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
}

model Solicitud_Computo {
  Pk_folio_ticket   String   @id @db.VarChar(100)
  C_Interno         String   @db.VarChar(100)
  Email_Empleado    String   @db.VarChar(100)
  Asesor            String?  @db.VarChar(100)
  Tipo_Servicio     String?  @db.VarChar(100)
  Descripcion       String?  @db.Text
  Fecha_Realizacion DateTime @default(now()) @db.Date
  Estado            String   @default("PENDIENTE")

  equipo   Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno])
  empleado Empleados          @relation(fields: [Email_Empleado], references: [Email])
}

model Costos_Computo {
  Id_Costo          Int      @id @default(autoincrement())
  Fecha             DateTime
  Servicio          String   @db.Text
  C_Interno         String   @db.VarChar(100)
  Costo_Refacciones Float
  Costo_MO          Float?
  Total             Float
  Proveedor         String   @db.Text
  Empresa           String   @db.Text
  Tipo_Mtto         String   @db.Text
  Factura_CDG       String?  @db.Text

  equipo Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
}
