generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Empleados {
  Email                     String                         @id @db.VarChar(50)
  Password                  String
  Nombre_Empleado           String                         @db.VarChar(60)
  A_Paterno                 String                         @db.VarChar(60)
  A_Materno                 String?                        @db.VarChar(60)
  Cargo                     String?                        @db.VarChar(60)
  Departamento              String?                        @db.VarChar(80)
  Rol                       String                         @default("USER")
  Estatus_Acceso            String                         @default("Activo")
  Ultimo_Cambio_Password    DateTime?
  Expiracion_Pin            DateTime?
  Pin_Temporal              String?
  Admin_TI                  Boolean                        @default(false)
  cajaChica                 Caja_Chica[]
  comprobacionGastos        Comprobacion_Gastos[]
  historial_propios         Historial_Empleados[]
  historial_autos           Historial_Registro_Automovil[]
  historialRegistroComputos Historial_Registro_Computo[]
  autos_encargados          Inventario_Automoviles[]       @relation("EncargadoAuto")
  inventarioComputos        Inventario_Computo[]
  procesos                  Procesos[]
  programas_anuales         Programa_Anual[]
  solicitudes               Solicitud[]
  solicitudComputos         Solicitud_Computo[]
  telefonos                 Telefono[]
  viaticos                  Viaticos[]
}

model Inventario_Automoviles {
  Consecutivo       String                         @id @db.VarChar(10)
  Placa             String                         @unique @db.VarChar(20)
  Marca             String?                        @db.VarChar(50)
  Modelo            String?                        @db.VarChar(50)
  Color             String?                        @db.VarChar(40)
  Linea             String?                        @db.VarChar(20)
  Estado_Unidad     Boolean                        @default(true)
  Email_encargado   String?                        @db.VarChar(100)
  Numero_Serie      String?
  Poliza_Seguro     String?
  Departamento      String?
  Contrato          String?
  Ubicacion         String?
  Percance          String?
  Estatus_Operativo String                         @default("Activo en flota") @db.VarChar(30)
  Kilometraje       Int?
  checklists        Checklist[]
  costos            Costos_Mantenimiento[]
  documentos        Documentos_Unidad[]
  bitacora_autos    Historial_Auto[]
  historial_reg     Historial_Registro_Automovil[]
  encargado         Empleados?                     @relation("EncargadoAuto", fields: [Email_encargado], references: [Email])
  solicitudes       Solicitud[]
  verificaciones    Verificacion_Vehicular[]
  costos_gasolina   Costos_Gasolina[]
  costos_peajes     Costos_Peajes[]
}

model Telefono {
  Email_Empleado String    @db.VarChar(50)
  No_Telefonico  String    @db.VarChar(15)
  empleado       Empleados @relation(fields: [Email_Empleado], references: [Email], onDelete: Cascade)

  @@id([Email_Empleado, No_Telefonico])
}

model Historial_Registro_Automovil {
  Id_Historial_Reg Int                    @id @default(autoincrement())
  Consecutivo      String                 @db.VarChar(10)
  Placa            String?                @db.VarChar(10)
  Marca            String?                @db.VarChar(20)
  Modelo           String?                @db.VarChar(20)
  Color            String?                @db.VarChar(15)
  Linea            String?                @db.VarChar(15)
  Email_Personal   String?                @db.VarChar(50)
  Fecha_Cambio     DateTime               @default(now())
  auto             Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
  empleado         Empleados?             @relation(fields: [Email_Personal], references: [Email])
}

model Historial_Auto {
  Id_Historial   Int                    @id @default(autoincrement())
  Consecutivo    String                 @db.VarChar(10)
  Placa_Actual   String?                @db.VarChar(10)
  Kilometraje    Int?
  Estado_Actual  Boolean                @default(true)
  Descripcion    String?
  Fecha_Registro DateTime               @default(now())
  auto           Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Checklist {
  id           Int                    @id @default(autoincrement())
  Consecutivo  String
  Titulo       String
  Ruta_PDF     String
  Fecha_Subida DateTime               @default(now())
  vehiculo     Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Documentos_Unidad {
  id               Int                    @id @default(autoincrement())
  Consecutivo      String                 @db.VarChar(10)
  Titulo           String                 @db.VarChar(100)
  Ruta_PDF         String
  Fecha_Subida     DateTime               @default(now())
  Aviso_Dias       Int?
  Fecha_Expiracion DateTime?              @db.Date
  Notificado       Boolean                @default(false)
  vehiculo         Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Historial_Empleados {
  Id_Historial_Emp Int       @id @default(autoincrement())
  Email_Empleado   String    @db.VarChar(50)
  Nombre           String?   @db.VarChar(60)
  A_Paterno        String?   @db.VarChar(60)
  A_Materno        String?   @db.VarChar(60)
  Cargo            String?   @db.VarChar(60)
  Departamento     String?   @db.VarChar(80)
  Fecha_Cambio     DateTime  @default(now())
  empleado         Empleados @relation(fields: [Email_Empleado], references: [Email], onDelete: Cascade)
}

model Solicitud {
  Pk_folio_ticket   String                 @id @db.VarChar(25)
  Consecutivo       String                 @db.VarChar(10)
  Email_Empleado    String                 @db.VarChar(50)
  Kilometraje       Int?
  Evidencia         String?
  Descripcion       String?
  Fecha_Realizacion DateTime               @default(now()) @db.Date
  Estado            String                 @default("PENDIENTE")
  Fecha_Cita        String?                @db.VarChar(50)
  Hora_Cita         String?                @db.VarChar(20)
  Lugar_Cita        String?
  Asesor            String?                @db.VarChar(50)
  Num_Asesor        String?
  Tipo_Servicio     String?                @db.VarChar(30)
  Link_Taller       String?
  Foto_Evidencia    String?
  procesos          Procesos[]
  auto              Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo])
  empleado          Empleados              @relation(fields: [Email_Empleado], references: [Email])
}

model Procesos {
  Id_Proceso      Int       @id @default(autoincrement())
  Pk_folio_ticket String    @db.VarChar(25)
  Email_Empleado  String    @db.VarChar(50)
  Detalle_Proceso String?
  Fecha_Hora      DateTime  @default(now())
  empleado        Empleados @relation(fields: [Email_Empleado], references: [Email])
  ticket          Solicitud @relation(fields: [Pk_folio_ticket], references: [Pk_folio_ticket], onDelete: Cascade)
}

model Costos_Mantenimiento {
  Id_Costo          Int                    @id @default(autoincrement())
  Fecha             DateTime
  Servicio          String
  Consecutivo       String                 @db.VarChar(10)
  Costo_MO          Float
  Costo_Refacciones Float
  Total             Float
  Proveedor         String
  Empresa           String
  Tipo_Mtto         String
  Factura_CDG       String?
  auto              Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Verificacion_Vehicular {
  Id_Verificacion    Int                    @id @default(autoincrement())
  Consecutivo        String                 @db.VarChar(10)
  Anio               Int
  Periodo            Int
  Fecha_Inicio_Plazo DateTime               @db.Date
  Fecha_Fin_Plazo    DateTime               @db.Date
  Fecha_Realizacion  DateTime?              @db.Date
  Evidencia_PDF      String?
  Costo              Float?
  Estado             String                 @default("PENDIENTE")
  vehiculo           Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Programa_Anual {
  Id_Programa     Int            @id @default(autoincrement())
  Anio            Int
  Categoria       String
  Ejecuta         String
  Observaciones   String?
  Email_Encargado String?        @db.VarChar(50)
  encargado       Empleados?     @relation(fields: [Email_Encargado], references: [Email])
  meses           Programa_Mes[]

  @@unique([Anio, Categoria])
}

model Programa_Mes {
  Id          Int            @id @default(autoincrement())
  Id_Programa Int
  Mes         Int
  Programado  Boolean        @default(false)
  Realizado   Boolean        @default(false)
  programa    Programa_Anual @relation(fields: [Id_Programa], references: [Id_Programa], onDelete: Cascade)

  @@unique([Id_Programa, Mes])
}

model Inventario_Computo {
  Empresa               String?                      @db.VarChar(100)
  Marca                 String?                      @db.VarChar(100)
  Modelo                String?                      @db.VarChar(100)
  Service_Tag           String?                      @db.VarChar(100)
  Email_Empleado        String?                      @db.VarChar(100)
  Departamento          String?                      @db.VarChar(100)
  Puesto_Proyecto       String?                      @db.VarChar(100)
  Fecha_CR              DateTime?                    @db.Date
  Proveedor             String?                      @db.VarChar(100)
  CR                    String?                      @db.VarChar(100)
  C_Interno             String                       @id @db.VarChar(100)
  Cargador              String?                      @db.VarChar(100)
  Estatus               String?                      @default("Asignado") @db.VarChar(100)
  N_EMP                 String?                      @db.VarChar(100)
  Tipo                  String?                      @db.VarChar(100)
  Usuario               String?                      @db.VarChar(100)
  costos                Costos_Computo[]
  documentos            Documentos_Computo[]
  Historial_Partes      Historial_Partes[]
  historial_reg         Historial_Registro_Computo[]
  empleado              Empleados?                   @relation(fields: [Email_Empleado], references: [Email])
  Plan_Mantenimiento    Plan_Mantenimiento[]
  Reporte_Mantenimiento Reporte_Mantenimiento[]
  solicitudes           Solicitud_Computo[]
}

model Historial_Registro_Computo {
  Id_Historial_Reg Int                @id @default(autoincrement())
  Email_Personal   String?            @db.VarChar(100)
  Fecha_Cambio     DateTime           @default(now())
  Detalle          String?
  C_Interno        String             @db.VarChar(100)
  equipo           Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
  empleado         Empleados?         @relation(fields: [Email_Personal], references: [Email])
}

model Documentos_Computo {
  id           Int                @id @default(autoincrement())
  Titulo       String             @db.VarChar(150)
  Ruta_PDF     String
  Fecha_Subida DateTime           @default(now())
  C_Interno    String             @db.VarChar(100)
  equipo       Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
}

model Solicitud_Computo {
  Pk_folio_ticket   String             @id @db.VarChar(100)
  Email_Empleado    String             @db.VarChar(100)
  Asesor            String?            @db.VarChar(100)
  Tipo_Servicio     String?            @db.VarChar(100)
  Descripcion       String?
  Fecha_Realizacion DateTime           @default(now()) @db.Date
  Estado            String             @default("PENDIENTE")
  C_Interno         String             @db.VarChar(100)
  equipo            Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno])
  empleado          Empleados          @relation(fields: [Email_Empleado], references: [Email])
}

model Costos_Computo {
  Id_Costo          Int                @id @default(autoincrement())
  Fecha             DateTime
  Servicio          String
  Costo_Refacciones Float
  Costo_MO          Float?
  Total             Float
  Proveedor         String
  Empresa           String
  Tipo_Mtto         String
  Factura_CDG       String?
  C_Interno         String             @db.VarChar(100)
  equipo            Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
}

model Caja_Chica {
  Id_CajaChica   Int        @id @default(autoincrement())
  Fecha          DateTime   @db.Date
  No_Factura     String?    @db.VarChar(100)
  Concepto       String
  Cargo          Float?     @default(0)
  Abono          Float?     @default(0)
  Saldo          Float      @default(0)
  Email_Empleado String?    @db.VarChar(50)
  Evidencia_PDF  String?
  Fecha_Registro DateTime   @default(now())
  Anio           Int        @default(2026)
  Semana         Int        @default(1)
  empleado       Empleados? @relation(fields: [Email_Empleado], references: [Email])
}

model Viaticos {
  Id_Viatico     Int        @id @default(autoincrement())
  Email_Empleado String?    @db.VarChar(50)
  Fecha_Registro DateTime   @default(now())
  Anio           Int        @default(2026)
  Categoria      String?    @db.VarChar(50)
  Concepto       String?    @db.VarChar(150)
  Destino        String?    @db.VarChar(150)
  Evidencia_PDF  String?
  Fecha          DateTime?  @db.Date
  Importe        Float?     @default(0)
  Observaciones  String?
  Origen         String?    @db.VarChar(150)
  Semana         Int        @default(1)
  Vehiculo       String?    @db.VarChar(100)
  empleado       Empleados? @relation(fields: [Email_Empleado], references: [Email])
}

model Comprobacion_Gastos {
  Id             Int       @id @default(autoincrement())
  Email_Empleado String    @db.VarChar(50)
  Fecha          DateTime? @db.Date
  No_Factura     String?   @db.VarChar(100)
  Concepto       String
  Abono          Float?    @default(0)
  Cargo          Float?    @default(0)
  Saldo          Float?    @default(0)
  Evidencia_PDF  String?
  Fecha_Registro DateTime  @default(now())
  Anio           Int       @default(2026)
  Semana         Int       @default(1)
  empleado       Empleados @relation(fields: [Email_Empleado], references: [Email])
}

model Bitacora_Auditoria {
  Id_Auditoria Int      @id @default(autoincrement())
  Usuario      String   @db.VarChar(100)
  Accion       String   @db.VarChar(50)
  Modulo       String   @db.VarChar(50)
  Detalle      String
  Fecha        DateTime @default(now())
}

model Edificio {
  Id_Edificio         Int                   @id @default(autoincrement())
  Sucursal            String                @db.VarChar(150)
  Direccion           String
  Departamentos       String
  Foto_Portada        String?
  Activo              Boolean               @default(true)
  Fecha_Creacion      DateTime              @default(now())
  inspecciones        Inspeccion_Edificio[]
}

model Foto_Inspeccion_Edificio {
  Id_Foto             Int                 @id @default(autoincrement())
  Id_Inspeccion       Int
  Url_Foto            String
  Descripcion         String?             @db.VarChar(255)
  Fecha_Subida        DateTime            @default(now())
  inspeccion          Inspeccion_Edificio @relation(fields: [Id_Inspeccion], references: [Id_Inspeccion], onDelete: Cascade)
}

model Historial_Partes {
  Id_Parte              Int                   @id @default(autoincrement())
  Id_Reporte            Int
  C_Interno             String                @db.VarChar(100)
  Nombre_Parte          String                @db.VarChar(150)
  Parte_Anterior        String?               @db.VarChar(200)
  Parte_Nueva           String?               @db.VarChar(200)
  Motivo_Cambio         String?
  Costo                 Float?                @default(0)
  Fecha_Cambio          DateTime              @default(now())
  Evidencia_URL         String?
  equipo                Inventario_Computo    @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
  reporte               Reporte_Mantenimiento @relation(fields: [Id_Reporte], references: [Id_Reporte], onDelete: Cascade)
}

model Inspeccion_Edificio {
  Id_Inspeccion            Int                        @id @default(autoincrement())
  Id_Edificio              Int
  Consecutivo              String                     @db.VarChar(50)
  Fecha_Inspeccion         DateTime                   @default(now())
  Inspector                String?                    @db.VarChar(100)
  Estado                   String                     @default("PENDIENTE")
  Datos_Formato            String?
  Observaciones            String?
  fotos                    Foto_Inspeccion_Edificio[]
  areas                    Inspeccion_Area[]
  edificio                 Edificio                   @relation(fields: [Id_Edificio], references: [Id_Edificio], onDelete: Cascade)
}

model Inspeccion_Area {
  Id_Area         Int                 @id @default(autoincrement())
  Id_Inspeccion   Int
  Nombre          String              @db.VarChar(150)
  Puertas         Int                 @default(0)
  Luminarias      Int                 @default(0)
  Estado          String              @db.VarChar(50)
  Observaciones   String?
  Categorias      String?
  Inspeccion      Inspeccion_Edificio @relation(fields: [Id_Inspeccion], references: [Id_Inspeccion], onDelete: Cascade)
  detalles        Inspeccion_Detalle[]
}

model Inspeccion_Detalle {
  Id_Detalle      Int                 @id @default(autoincrement())
  Id_Area         Int
  Item            String              @db.VarChar(200)
  Estado          String              @db.VarChar(50)
  Observaciones   String?
  Area            Inspeccion_Area     @relation(fields: [Id_Area], references: [Id_Area], onDelete: Cascade)
}

model Plan_Mantenimiento {
  Id_Plan               Int                     @id @default(autoincrement())
  C_Interno             String                  @db.VarChar(100)
  Tipo_Mtto             String                  @db.VarChar(50)
  Frecuencia_Meses      Int                     @default(6)
  Fecha_Inicio          DateTime                @db.Date
  Fecha_Proximo         DateTime                @db.Date
  Activo                Boolean                 @default(true)
  Observaciones         String?
  Creado_Por            String?                 @db.VarChar(100)
  Fecha_Creacion        DateTime                @default(now())
  equipo                Inventario_Computo      @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
  reportes              Reporte_Mantenimiento[]
}

model Reporte_Mantenimiento {
  Id_Reporte         Int                @id @default(autoincrement())
  Consecutivo_FRM    String             @unique @db.VarChar(20)
  Id_Plan            Int
  C_Interno          String             @db.VarChar(100)
  Fecha_Programada   DateTime           @db.Date
  Fecha_Ejecucion    DateTime?          @db.Date
  Tipo_Mtto          String             @db.VarChar(50)
  Tecnico            String?            @db.VarChar(100)
  Limpieza_Interna   Boolean            @default(false)
  Limpieza_Externa   Boolean            @default(false)
  Revision_Software  Boolean            @default(false)
  Actualizacion_SO   Boolean            @default(false)
  Revision_Hardware  Boolean            @default(false)
  Respaldo_Info      Boolean            @default(false)
  Revision_Antivirus Boolean            @default(false)
  Revision_Red       Boolean            @default(false)
  Actividades_Extra  String?
  Observaciones      String?
    Datos_Formato      String?
    Estado             String             @default("PENDIENTE")
  Email_Notificado   String?            @db.VarChar(100)
  Confirmado         Boolean?
  Motivo_Rechazo     String?
  Foto_Antes         String?
  Foto_Despues       String?
  Fotos_Extra        String?
  Firma_Tecnico      String?
  Firma_Responsable  String?
  Fecha_Creacion     DateTime           @default(now())
  partes_cambiadas   Historial_Partes[]
  equipo             Inventario_Computo @relation(fields: [C_Interno], references: [C_Interno], onDelete: Cascade)
  plan               Plan_Mantenimiento @relation(fields: [Id_Plan], references: [Id_Plan], onDelete: Cascade)
}

model Programacion_Semanal {
  Id                   Int       @id @default(autoincrement())
  Fecha_Sol            DateTime  @db.Date
  Partida              Int
  Servicio_Producto    String
  Monto                Float
  Proveedor            String
  Empresa              String
  Fecha_Pago           DateTime? @db.Date
  Factura_Comprobacion String?   @unique
  Usuario              String
  Estatus              String    @default("Pendiente")
  Monto_Pagado         Float?    @default(0)
  Fecha_Registro       DateTime  @default(now())
}

model Inventario_Aires_Acondicionados {
  N_Interno    String   @id @db.VarChar(100)
  Empresa      String?  @db.VarChar(100)
  Tipo         String?  @db.VarChar(100)
  Descripcion  String?
  Modelo       String?  @db.VarChar(100)
  Departamento String?  @db.VarChar(100)
  Ubicacion    String?  @db.VarChar(100)
  Proveedor    String?  @db.VarChar(100)
  Estatus      String?  @default("Activo") @db.VarChar(100)
  Fecha_Alta   DateTime @default(now())
}

model Inventario_Telefonia {
  N_Interno   String   @id @db.VarChar(100)
  Empresa     String?  @db.VarChar(100)
  Cliente     String?  @db.VarChar(100)
  Marca       String?  @db.VarChar(100)
  Modelo      String?  @db.VarChar(100)
  Usuario     String?  @db.VarChar(150)
  Departamento String? @db.VarChar(100)
  Ubicacion    String? @db.VarChar(100)
  IMEI        String?  @db.VarChar(100)
  ICCID       String?  @db.VarChar(100)
  Region_SIM  String?  @db.VarChar(50)
  Cuenta      String?  @db.VarChar(100)
  Numero      String?  @db.VarChar(50)
  Plan        String?  @db.VarChar(150)
  PZO         Int?     @default(0)
  Estatus     String?  @default("Activo") @db.VarChar(100)
  Fecha_Alta  DateTime @default(now())
}

model Costos_Gasolina {
  Id_Gasto      Int                    @id @default(autoincrement())
  Fecha_Hora    DateTime
  Consecutivo   String                 @db.VarChar(10)
  Estacion      String
  Combustible   String
  Litros        Float
  Precio        Float
  Total         Float
  Fecha_Registro DateTime              @default(now())
  auto          Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}

model Costos_Peajes {
  Id_Peaje         Int                    @id @default(autoincrement())
  Tag              String
  Consecutivo      String                 @db.VarChar(10)
  Fecha_Hora       DateTime
  Caseta           String
  Carril           String
  Clase            String
  Importe          Float
  Fecha_Aplicacion String?
  Hora_Aplicacion  String?
  Consecar         String?
  Fecha_Registro   DateTime               @default(now())
  auto             Inventario_Automoviles @relation(fields: [Consecutivo], references: [Consecutivo], onDelete: Cascade)
}
